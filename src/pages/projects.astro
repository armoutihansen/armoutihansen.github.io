---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";

const projectGroups = [
  "Research code",
  "Applied data science",
  "AI and search tooling",
  "Software packages and tools",
  "Learning exercises"
].map((title) => ({
  title,
  headingId: `project-group-${title.toLowerCase().replaceAll(" ", "-")}`,
  projects: projects.filter((project) => project.group === title)
})).filter((group) => group.projects.length > 0);
---

<BaseLayout title="Projects" description="Selected quantitative data science, econometrics, and research projects by Jesper Armouti-Hansen.">
  <section class="hero">
    <p class="eyebrow">Projects</p>
    <h1>Applied quantitative work</h1>
    <p class="lead">
      A curated view of research code, applied data science, AI tooling, and software projects.
    </p>
  </section>

  <section class="section">
    {projectGroups.map((group) => (
      <section class="project-group" aria-labelledby={group.headingId}>
        <SectionHeading id={group.headingId} title={group.title} />
        <div class="bib-list">
          {group.projects.map((project) => <ProjectCard project={project} />)}
        </div>
      </section>
    ))}
  </section>
</BaseLayout>
