---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";

const projectGroups = [
  {
    title: "Research code",
    intro: "Replication packages, simulations, and analysis code tied directly to papers and working research."
  },
  {
    title: "Applied data science",
    intro: "Case-study work where modeling, cleaning, and interpretation are applied to operational data."
  },
  {
    title: "AI and search tooling",
    intro: "Tools that explore retrieval, ranking, generation, and agentic workflows."
  },
  {
    title: "Software packages and tools",
    intro: "Reusable technical projects and published knowledge infrastructure."
  },
  {
    title: "Learning exercises",
    intro: "Smaller practice projects kept visible as evidence of deliberate skill-building, not as primary portfolio work."
  }
].map((group) => ({
  ...group,
  headingId: `project-group-${group.title.toLowerCase().replaceAll(" ", "-")}`,
  projects: projects.filter((project) => project.group === group.title)
})).filter((group) => group.projects.length > 0);
---

<BaseLayout title="Projects" description="Selected quantitative data science, econometrics, and research projects by Jesper Armouti-Hansen.">
  <section class="hero">
    <p class="eyebrow">Projects</p>
    <h1>Applied quantitative work</h1>
    <p class="lead">
      A curated view of research code, applied data science, AI tooling, and software projects.
    </p>
  </section>

  <section class="section">
    {projectGroups.map((group) => (
      <section class="project-group" aria-labelledby={group.headingId}>
        <SectionHeading id={group.headingId} title={group.title} intro={group.intro} />
        <div class:list={["bib-list", { "compact-list": group.title === "Learning exercises" }]}>
          {group.projects.map((project) => (
            <ProjectCard project={project} compact={group.title === "Learning exercises"} />
          ))}
        </div>
      </section>
    ))}
  </section>
</BaseLayout>
