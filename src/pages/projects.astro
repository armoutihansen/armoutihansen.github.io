---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkItem from "../components/WorkItem.astro";
import GitHubStrip from "../components/GitHubStrip.astro";
import { projectGroups, projects } from "../data/projects";

const groupTitles = new Set(projectGroups.map((group) => group.title));
const duplicateTitles = projects
  .map((project) => project.title)
  .filter((title, index, all) => all.indexOf(title) !== index);
const unknownGroups = projects
  .map((project) => project.primaryGroup)
  .filter((group) => !groupTitles.has(group as (typeof projectGroups)[number]["title"]));

if (duplicateTitles.length > 0) {
  throw new Error(`Duplicate project titles: ${[...new Set(duplicateTitles)].join(", ")}`);
}
if (unknownGroups.length > 0) {
  throw new Error(`Unknown project groups: ${[...new Set(unknownGroups)].join(", ")}`);
}

const LINK_GROUP = "Also on GitHub";

const grouped = projectGroups
  .map((group) => ({
    title: group.title,
    intro: group.intro,
    headingId: `work-${group.title.toLowerCase().replace(/[^a-z]+/g, "-").replace(/^-|-$/g, "")}`,
    isLinkGroup: group.title === LINK_GROUP,
    projects: projects.filter((project) => project.primaryGroup === group.title)
  }))
  .filter((group) => group.projects.length > 0);
---

<BaseLayout
  title="Work"
  description="Selected quantitative analysis, modeling, and research-code work by Jesper Armouti-Hansen."
>
  <header class="page-hero">
    <p class="eyebrow">Selected work</p>
    <h1>Analysis, modeling, and research code</h1>
    <p class="lead">
      Each project appears once, with the question it addresses, the method, and the result.
    </p>
  </header>

  <GitHubStrip />

  <div class="section">
    {grouped.map((group) => (
      <section class="group" aria-labelledby={group.headingId}>
        <div class="group__head">
          <h2 id={group.headingId}>{group.title}</h2>
          <p>{group.intro}</p>
        </div>
        {group.isLinkGroup ? (
          <p class="morelist">
            {group.projects.map((project, i) => (
              <Fragment>
                <a href={project.href} rel="noreferrer">{project.title}</a>
                {i < group.projects.length - 1 && <span aria-hidden="true"> · </span>}
              </Fragment>
            ))}
          </p>
        ) : (
          <div class="worklist">
            {group.projects.map((project, i) => <WorkItem project={project} index={i + 1} />)}
          </div>
        )}
      </section>
    ))}
  </div>
</BaseLayout>
