---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ExperienceEntry from "../components/ExperienceEntry.astro";
import { education } from "../data/education";
import { experience } from "../data/experience";
import { capabilities, profile, profileLink, skillGroups } from "../data/profile";
import { teaching } from "../data/teaching";

const linkedIn = profileLink("linkedin");
---

<BaseLayout title="CV" description={`CV for ${profile.name} — data scientist with an economics PhD, working in statistical modeling, machine learning, and model evaluation.`}>
  <header class="page-hero cv-hero">
    <div class="cv-hero__main">
      <img
        class="cv-portrait"
        src="/images/avatar3.webp"
        alt={`Pixel-art portrait of ${profile.name}`}
        width="400"
        height="400"
        loading="eager"
        decoding="async"
      />
      <div class="cv-hero__text">
        <p class="eyebrow">Curriculum vitae</p>
        <h1>{profile.name}</h1>
        <p class="lead">{profile.summary}</p>
      </div>
    </div>
    <div class="actions">
      <a class="btn btn--primary" href="/CV_JAH.pdf">Download PDF</a>
      <a class="btn" href={`mailto:${profile.email}`}>Email</a>
      <a class="btn" href={linkedIn.href} rel="me noreferrer">{linkedIn.label}</a>
    </div>
  </header>

  <section class="section">
    <SectionHeading title="Experience" />
    <div class="timeline">
      {experience.map((item) => <ExperienceEntry item={item} />)}
    </div>
  </section>

  <section class="section">
    <SectionHeading
      title="Strengths"
      intro="Statistical modeling, model evaluation, and forecasting, backed by an economics PhD."
    />
    <div class="capabilities">
      {capabilities.map((item) => (
        <article class="capability">
          <h3>{item.label}</h3>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <SectionHeading
      title="Skills"
      intro="The concrete stack: languages, libraries, methods, and tools."
    />
    <dl class="skillset">
      {skillGroups.map((group) => (
        <div class="skillset__row">
          <dt class="skillset__label">{group.label}</dt>
          <dd class="skillset__items">
            {group.items.map((item) => <span class="chip">{item}</span>)}
          </dd>
        </div>
      ))}
    </dl>
  </section>

  <section class="section">
    <SectionHeading title="Education" />
    <div class="timeline">
      {education.map((item) => (
        <article class:list={["entry", { "entry--logo": item.logo }]}>
          <div class="entry__body">
            <p class="entry__meta">{item.period} · {item.location}</p>
            <h3>{item.degree}</h3>
            <p class="entry__where">{item.institution}{item.detail && `. ${item.detail}`}</p>
          </div>
          {item.logo && (
            <span class="entry__logo">
              <img src={item.logo} alt={`${item.institution} logo`} loading="lazy" decoding="async" />
            </span>
          )}
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <SectionHeading title="Teaching & supervision" intro={teaching.summary} />
    <ul class="courses">
      {teaching.courses.map((course) => (
        <li class="course">
          <div class="course__body">
            <h3 class="course__title">{course.title}</h3>
            <p class="course__role">{course.role}</p>
          </div>
          <p class="course__years">{course.years}</p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .cv-hero {
    max-width: none;
  }

  .cv-hero__main {
    display: grid;
    gap: clamp(1.3rem, 4vw, 2rem);
    align-items: start;
  }

  .cv-hero__text {
    max-width: 38rem;
  }

  .cv-portrait {
    width: clamp(150px, 24vw, 220px);
    height: auto;
    aspect-ratio: 1 / 1;
    image-rendering: pixelated;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--paper-sunk);
    box-shadow: var(--shadow);
  }

  @media (min-width: 40em) {
    .cv-hero__main {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: clamp(1.6rem, 4vw, 2.6rem);
    }
    .cv-hero__text {
      order: 1;
    }
    .cv-portrait {
      order: 2;
    }
  }
</style>
