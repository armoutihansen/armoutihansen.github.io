---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { experience } from "../data/experience";
import { profile, skills } from "../data/profile";

const education = [
  {
    degree: "PhD in Economics, Dr. rer. pol.",
    institution: "University of Cologne",
    period: "2015 – 2021",
    detail: "Summa cum laude. Focus on microeconomics, statistics, and econometrics."
  },
  {
    degree: "MSc International Economics and Public Policy",
    institution: "University of Mainz",
    period: "2012 – 2014",
    detail: "Focus on microeconomics, statistics, and econometrics."
  },
  {
    degree: "BA Financial Management and Services",
    institution: "Copenhagen Business Academy",
    period: "2008 – 2012",
    detail: ""
  },
  {
    degree: "Exchange semester",
    institution: "European University of Cyprus",
    period: "2010",
    detail: ""
  }
];

const languages = [
  "Danish (native)",
  "English (full professional proficiency)",
  "German (professional proficiency)"
];
---

<BaseLayout title="CV" description="CV and professional profile for Jesper Armouti-Hansen, quantitative data scientist and economics PhD.">
  <section class="hero">
    <p class="eyebrow">CV</p>
    <h1>Curriculum vitae</h1>
    <p class="lead">{profile.summary}</p>
    <ul class="inline-list">
      <li><a href="/CV_JAH.pdf">Download PDF →</a></li>
      <li><a href={`mailto:${profile.email}`}>{profile.email}</a></li>
    </ul>
  </section>

  <section class="section">
    <SectionHeading title="Experience" />
    <div class="bib-list">
      {experience.map((item) => (
        <article class="bib-item">
          <p class="meta-period">{item.period} · {item.location}</p>
          <h3>{item.role}, {item.organization}</h3>
          <ul>
            {item.bullets.map((bullet) => <li>{bullet}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <SectionHeading title="Education" />
    <div class="bib-list">
      {education.map((item) => (
        <article class="bib-item">
          <p class="meta-period">{item.period}</p>
          <h3>{item.degree}</h3>
          <p class="description">{item.institution}{item.detail && `. ${item.detail}`}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <SectionHeading title="Skills" />
    <p class="mono-label">Quantitative</p>
    <p>{skills.quantitative.join(" · ")}</p>
    <p class="mono-label">Programming</p>
    <p>{skills.programming.join(" · ")}</p>
    <p class="mono-label">Research areas</p>
    <p>{skills.research.join(" · ")}</p>
    <p class="mono-label">Languages</p>
    <p>{languages.join(" · ")}</p>
  </section>
</BaseLayout>
