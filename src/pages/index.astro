---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import WorkItem from "../components/WorkItem.astro";
import PublicationItem from "../components/PublicationItem.astro";
import { experience } from "../data/experience";
import { capabilities, profile } from "../data/profile";
import { projects } from "../data/projects";
import { publications } from "../data/publications";
import { pad2 } from "../data/format";

const featuredProjects = projects.filter((project) => project.featured);
const featuredPublications = publications.filter((item) => item.type === "Publication").slice(0, 2);
const recentExperience = experience.slice(0, 2);
const paperCount = publications.filter((item) => item.type === "Publication").length;

const credibility = [
  { figure: String(paperCount), label: "peer-reviewed papers" },
  { figure: "PhD", label: "economics, summa cum laude" },
  { figure: "5", label: "journals refereed for" },
  { figure: "60+", label: "theses supervised" }
];
---

<BaseLayout>
  <section class="hero">
    <div class="hero__intro">
      <p class="eyebrow hero__eyebrow reveal reveal-1">{profile.title}</p>
      <h1 class="hero__name reveal reveal-1">Jesper <br />Armouti-Hansen</h1>
      <p class="hero__lead reveal reveal-2">{profile.summary}</p>
      <p class="hero__note reveal reveal-3">{profile.tagline}</p>
      <div class="actions reveal reveal-3">
        <a class="btn btn--primary" href="/CV_JAH.pdf">Download CV</a>
        <a class="btn" href={`mailto:${profile.email}`}>Email</a>
        <a class="btn" href="https://www.linkedin.com/in/jesper-a-h/" rel="me noreferrer">LinkedIn</a>
      </div>
    </div>
    <aside class="hero__aside reveal reveal-4" aria-label="Profile at a glance">
      <div class="portrait">
        <img src="/images/profile.webp" alt={`Portrait of ${profile.name}`} loading="eager" />
      </div>
      <dl class="facts">
        <div><dt>Location</dt><dd>{profile.location}</dd></div>
        <div><dt>Focus</dt><dd>Model evaluation &amp; statistical modeling</dd></div>
        <div><dt>Stack</dt><dd>Python · SQL · R</dd></div>
        <div><dt>Languages</dt><dd>English · German · Danish</dd></div>
      </dl>
    </aside>
  </section>

  <section class="section">
    <SectionHeading eyebrow="Profile" title="What I do" />
    <div class="capabilities">
      {capabilities.map((item, i) => (
        <article class="capability">
          <span class="capability__index">{pad2(i + 1)}</span>
          <h3>{item.label}</h3>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <SectionHeading
      eyebrow="Selected work"
      title="Analysis, models, and checks"
      intro="A few projects, each with the question it addresses, the method, and the result."
    />
    <div class="worklist">
      {featuredProjects.map((project, i) => <WorkItem project={project} index={i + 1} />)}
    </div>
    <p class="section__more"><a href="/projects/">All work</a></p>
  </section>

  <section class="section">
    <SectionHeading eyebrow="Experience" title="Where I've worked" />
    <div class="timeline">
      {recentExperience.map((item) => (
        <article class="entry">
          <p class="entry__meta">{item.period} · {item.location}</p>
          <h3>{item.role}, {item.organization}</h3>
          <ul>
            {item.bullets.map((bullet) => <li>{bullet}</li>)}
          </ul>
        </article>
      ))}
    </div>
    <p class="section__more"><a href="/cv/">Full CV</a></p>
  </section>

  <section class="section">
    <SectionHeading
      eyebrow="Background"
      title="Research & teaching"
      intro="A decade in academic economics — published research, refereeing for journals, and university teaching."
    />
    <div class="cred">
      {credibility.map((item) => (
        <div><strong>{item.figure}</strong><span>{item.label}</span></div>
      ))}
    </div>
    <div class="publist">
      {featuredPublications.map((publication) => <PublicationItem publication={publication} compact />)}
    </div>
    <p class="section__more"><a href="/publications/">Research background</a></p>
  </section>

  <section class="section">
    <SectionHeading eyebrow="Contact" title="Get in touch" />
    <p class="measure">
      Email is the best way to reach me — I'm glad to talk through a quantitative or modeling problem.
    </p>
    <ul class="linkrow linkrow--block">
      <li><a href={`mailto:${profile.email}`}>{profile.email}</a></li>
      <li><a href="https://www.linkedin.com/in/jesper-a-h/" rel="me noreferrer">LinkedIn</a></li>
      <li><a href="https://github.com/armoutihansen" rel="me noreferrer">GitHub</a></li>
    </ul>
  </section>
</BaseLayout>
