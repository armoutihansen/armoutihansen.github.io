---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import WorkItem from "../components/WorkItem.astro";
import Hero from "../components/Hero.astro";
import PublicationItem from "../components/PublicationItem.astro";
import ExperienceEntry from "../components/ExperienceEntry.astro";
import { experience } from "../data/experience";
import { capabilities, profile } from "../data/profile";
import { featuredProjects } from "../data/projects";
import { featuredPublications } from "../data/publications";
import { homeCredibility } from "../data/credibility";
import { pad2 } from "../data/format";

const featured = featuredProjects();
const featuredPubs = featuredPublications(2);
const recentExperience = experience.slice(0, 2);
const credibility = homeCredibility();
---

<BaseLayout>
  <Hero />

  <section class="section">
    <SectionHeading eyebrow="Profile" title="What I do" />
    <div class="capabilities">
      {capabilities.map((item, i) => (
        <article class="capability">
          <span class="capability__index">{pad2(i + 1)}</span>
          <h3>{item.label}</h3>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <SectionHeading
      eyebrow="Selected work"
      title="Analysis, models, and checks"
      intro="A few projects, each with the question it addresses, the method, and the result."
    />
    <div class="worklist worklist--grid">
      {featured.map((project, i) => <WorkItem project={project} index={i + 1} compact />)}
    </div>
    <p class="section__more"><a href="/projects/">All work</a></p>
  </section>

  <section class="section">
    <SectionHeading eyebrow="Experience" title="Where I've worked" />
    <div class="timeline">
      {recentExperience.map((item) => <ExperienceEntry item={item} />)}
    </div>
    <p class="section__more"><a href="/cv/">Full CV</a></p>
  </section>

  <section class="section">
    <SectionHeading
      eyebrow="Background"
      title="Research & teaching"
      intro="A decade in academic economics — published research, refereeing for journals, and university teaching."
    />
    <div class="cred">
      {credibility.map((item) => (
        <div><strong>{item.figure}</strong><span>{item.label}</span></div>
      ))}
    </div>
    <div class="publist">
      {featuredPubs.map((publication) => <PublicationItem publication={publication} compact />)}
    </div>
    <p class="section__more"><a href="/publications/">Research background</a></p>
  </section>

  <section class="section">
    <SectionHeading eyebrow="Contact" title="Get in touch" />
    <p class="measure">
      Email is the best way to reach me — I'm glad to talk through a quantitative or modeling problem.
    </p>
    <ul class="linkrow linkrow--block">
      <li><a href={`mailto:${profile.email}`}>{profile.email}</a></li>
      <li><a href="https://www.linkedin.com/in/jesper-a-h/" rel="me noreferrer">LinkedIn</a></li>
      <li><a href="https://github.com/armoutihansen" rel="me noreferrer">GitHub</a></li>
    </ul>
  </section>
</BaseLayout>
