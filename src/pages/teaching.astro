---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";

const teaching = [
  "Seminar on Current Topics in Microeconomics, undergraduate lecturer, since 2025",
  "Research Module on Applied Microeconomics and Management, graduate lecturer, 2022-2025",
  "Empirical Evaluation of Management Practices, graduate lecturer and tutor, 2019-2022",
  "Economics of Incentives in Organisations, graduate tutor, 2016 and 2020-2022",
  "Behavioral Management Science, undergraduate lecturer and tutor, 2017-2020",
  "Strategic Human Resource Management, graduate tutor, 2016-2019",
  "Seminar on Human Resource Management, graduate lecturer, 2017-2018"
];
---

<BaseLayout title="Teaching" description="Teaching and supervision experience in microeconomics, management, and behavioral economics.">
  <section class="page-hero">
    <p class="eyebrow">Teaching</p>
    <h1>Teaching and supervision</h1>
    <p class="lead">Teaching experience across microeconomics, management, behavioral economics, and empirical evaluation, including supervision of more than 60 bachelor and master theses.</p>
  </section>

  <section class="section">
    <SectionHeading title="Courses" />
    <ul class="list-panel">
      {teaching.map((item) => <li>{item}</li>)}
    </ul>
  </section>
</BaseLayout>
