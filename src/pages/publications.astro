---
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicationItem from "../components/PublicationItem.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ResearchStrip from "../components/ResearchStrip.astro";
import { journalPublications, otherWork } from "../data/publications";

const journals = journalPublications();
const other = otherWork();
---

<BaseLayout
  title="Research"
  description="Research background, publications, working papers, and replication packages by Jesper Armouti-Hansen."
>
  <header class="page-hero">
    <p class="eyebrow">Publications &amp; working papers</p>
    <h1>Research background</h1>
    <p class="lead">
      Four peer-reviewed papers in behavioral, organizational, and decision economics, plus
      working papers and replication code. The methods are econometric and the assumptions are
      stated; the replication packages are public.
    </p>
    <ResearchStrip />
  </header>

  <section class="section">
    <SectionHeading
      title="Journal publications"
      intro="Peer-reviewed work in behavioral, organizational, and decision economics."
    />
    <div class="publist">
      {journals.map((publication) => <PublicationItem publication={publication} />)}
    </div>
  </section>

  <section class="section">
    <SectionHeading
      title="Working papers & projects"
      intro="Current work and replication material: stated assumptions, public code, and interpretation."
    />
    <div class="publist">
      {other.map((publication) => <PublicationItem publication={publication} />)}
    </div>
  </section>
</BaseLayout>
