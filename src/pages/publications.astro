---
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicationItem from "../components/PublicationItem.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ResearchStrip from "../components/ResearchStrip.astro";
import { journalPublications, otherWork } from "../data/publications";
import { profile } from "../data/profile";

const journals = journalPublications();
const other = otherWork();
---

<BaseLayout
  title="Research"
  description={`Research background, publications, working papers, and replication packages by ${profile.name}.`}
>
  <header class="page-hero">
    <p class="eyebrow">Publications &amp; working papers</p>
    <h1>Research background</h1>
    <p class="lead">
      My work spans behavioral and organizational economics, contract theory, and choice
      theory &mdash; some theory, some experiments. Below are the published papers, plus working
      papers and projects still in progress.
    </p>
    <ResearchStrip />
  </header>

  <section class="section">
    <SectionHeading
      title="Journal publications"
      intro="Peer-reviewed articles in economics journals."
    />
    <div class="publist">
      {journals.map((publication) => <PublicationItem publication={publication} />)}
    </div>
  </section>

  <section class="section">
    <SectionHeading
      title="Working papers & projects"
      intro="Current work and replication material: stated assumptions, public code, and interpretation."
    />
    <div class="publist">
      {other.map((publication) => <PublicationItem publication={publication} />)}
    </div>
  </section>
</BaseLayout>
