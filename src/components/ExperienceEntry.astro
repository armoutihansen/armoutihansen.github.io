---
interface Props {
  item: {
    role: string;
    organization: string;
    period: string;
    location: string;
    bullets: string[];
    logo?: string;
  };
}

const { item } = Astro.props;
---

<article class:list={["entry", { "entry--logo": item.logo }]}>
  <div class="entry__body">
    <p class="entry__meta">{item.period} · {item.location}</p>
    <h3>{item.role}, {item.organization}</h3>
    <ul>
      {item.bullets.map((bullet) => <li>{bullet}</li>)}
    </ul>
  </div>
  {item.logo && (
    <span class="entry__logo">
      <img src={item.logo} alt={`${item.organization} logo`} loading="lazy" decoding="async" />
    </span>
  )}
</article>
