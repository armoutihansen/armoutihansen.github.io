---
import type { Project } from "../data/projects";

// The illustration panel for a Work item: caption (title, legend, optional
// metric toggle), the embedded figure or image, and a note. Rendered only when
// a project carries figure data. Its theme sync and toggle wiring are the host
// side of the figure embed channel (src/scripts/figure-embed-host.ts); the
// classes here are the contract that host queries.
interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<figure class="work__panel">
  <figcaption class="work__panel-cap">
    {project.figureTitle && <span class="work__panel-title">{project.figureTitle}</span>}
    {project.legend && (
      <span class="work__legend">
        {project.legend.map((l) => (
          <span><i style={`background:${l.color}`} />{l.label}</span>
        ))}
      </span>
    )}
    {project.controls && (
      <span class="work__toggle" role="tablist" aria-label={project.figureTitle}>
        {project.controls.map((c, i) => (
          <button
            type="button"
            class="work__toggle-btn"
            role="tab"
            data-key={c.key}
            aria-selected={i === 0 ? "true" : "false"}
          >{c.label}</button>
        ))}
      </span>
    )}
  </figcaption>
  <div class="work__panel-frame">
    {project.embed ? (
      <iframe src={project.embed} title={project.imageAlt ?? project.title} loading="lazy" />
    ) : (
      <img src={project.image} alt={project.imageAlt ?? project.title} loading="lazy" decoding="async" />
    )}
  </div>
  {project.figureNote && <p class="work__panel-note">{project.figureNote}</p>}
</figure>

<style>
  /* Illustration-panel chrome, co-located with the markup it styles. The entry
     rhythm, design tokens, and shared "ledger" list selectors stay in
     global.css — only this fully self-contained set lives here. See ADR 0004.
     The panel's placement (.work--figure grid) is WorkItem's concern and stays
     global; this owns the panel's interior. */
  .work__panel {
    margin: 0;
    display: grid;
    gap: 0.7rem;
    padding: clamp(0.9rem, 0.6rem + 1vw, 1.3rem);
    background: var(--paper-sunk);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .work__panel-cap {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.3rem 1rem;
  }

  .work__panel-title {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    font-weight: 600;
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--ink);
  }

  .work__legend {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.9rem;
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--track-meta);
    text-transform: uppercase;
    color: var(--faint);
  }

  .work__legend > span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .work__legend i {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
  }

  .work__toggle {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .work__toggle-btn {
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: 0.25rem 0.45rem;
    cursor: pointer;
    transition: color 0.16s ease, border-color 0.16s ease;
  }

  .work__toggle-btn:hover {
    color: var(--ink);
  }

  .work__toggle-btn[aria-selected="true"] {
    color: var(--accent-deep);
    border-color: var(--accent);
  }

  .work__panel-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    max-height: 460px;
    overflow: hidden;
    border-radius: var(--radius-sm);
    background: var(--paper-sunk);
  }

  .work__panel-frame iframe,
  .work__panel-frame img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .work__panel-frame img {
    object-fit: cover;
  }

  .work__panel-note {
    margin: 0;
    max-width: var(--measure);
    color: var(--muted);
    font-size: var(--fs-small);
    line-height: 1.5;
  }

  @media (max-width: 760px) {
    .work__panel-frame {
      aspect-ratio: 4 / 3;
    }
  }
</style>
