---
interface Props {
  project: {
    title: string;
    category: string;
    group?: string;
    status: string;
    summary: string;
    methods: string[];
    image?: string;
    imageAlt?: string;
    href: string;
  };
}

const { project } = Astro.props;
const external = project.href.startsWith("http");
const target = external ? "_blank" : undefined;
const rel = external ? "noreferrer" : undefined;
---

<article class:list={["bib-item", { "has-thumb": !!project.image }]}>
  {project.image && (
    <img class="thumb" src={project.image} alt={project.imageAlt ?? project.title} loading="lazy" />
  )}
  <div>
    <p class="meta-period">{project.status} · {project.category}</p>
    <h3>
      <a href={project.href} target={target} rel={rel}>{project.title}</a>
    </h3>
    <p class="description">{project.summary}</p>
    <p class="tags">{project.methods.join(" · ")}</p>
  </div>
</article>
