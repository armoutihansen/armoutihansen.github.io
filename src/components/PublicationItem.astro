---
interface Props {
  publication: {
    title: string;
    authors: string;
    venue: string;
    year: string;
    details: string;
    href: string;
    links?: { label: string; href: string }[];
    type: string;
    abstract: string;
  };
}

const { publication } = Astro.props;
---

<article class="bib-item">
  <p class="meta-period">{publication.year} · {publication.type}</p>
  <h3>{publication.title}</h3>
  <p class="authors">{publication.authors}</p>
  <p class="venue">{publication.venue}{publication.details && `, ${publication.details}`}</p>
  {(publication.links?.length || publication.href) && (
    <p class="links">
      {(publication.links ?? [{ label: "Link", href: publication.href }]).map((link) => (
        <a href={link.href} rel="noreferrer">{link.label}</a>
      ))}
    </p>
  )}
  {publication.abstract && (
    <details>
      <summary>Abstract</summary>
      <p>{publication.abstract}</p>
    </details>
  )}
</article>
