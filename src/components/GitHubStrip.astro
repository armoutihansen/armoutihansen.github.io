---
import gh from "../data/github.json";
import { lastMonths, type Contributions } from "../data/github-calendar";

const c = gh.contributions as Contributions;

// Mobile keeps the full last-12-months calendar; desktop narrows to the trailing
// 9 months to free a column for the languages panel. Both come from the same
// pure truncation helper so the math is tested, not hand-inlined here.
function strip(months: { label: string; col: number }[]) {
  const m = months.map((x) => ({ label: x.label, col: x.col }));
  // Drop a cramped leading label that would collide with the next one.
  if (m.length > 1 && m[1].col - m[0].col < 3) return m.slice(1);
  return m;
}

const full = { weeks: c.weeks, months: strip(c.months) };
const nine = (() => {
  const t = lastMonths(c, 9);
  return { weeks: t.weeks, months: strip(t.months) };
})();

const scale = [0, 1, 2, 3, 4];
const aria = `${c.total} contributions in the last year`;

// Top authored languages (byte-based, top-5 from the data layer). Bars are
// decorative; the visible "Name 79%" text carries the value to assistive tech.
const languages = gh.languages.map((l) => ({
  name: l.name,
  pct: l.pct,
  // Sub-0.5% languages round to 0 in the data; never show a literal "0%".
  display: l.pct < 1 ? "<1%" : `${l.pct}%`,
}));
---

<div class="ghstrip">
  <div class="ghstrip__top">
    <span class="ghstrip__label">Open source</span>
    <a class="ghstrip__link" href={gh.url} rel="me noreferrer">github.com/{gh.user} &rarr;</a>
  </div>

  <div class="ghstrip__body">
    <div class="ghstrip__calcol">
      {/* Desktop: trailing 9 months. */}
      <div class="ghcal ghcal--nine" style={`--nweeks: ${nine.weeks.length}`}>
        <div
          class="ghcal__months"
          style={`grid-template-columns: repeat(${nine.weeks.length}, minmax(0, 1fr))`}
          aria-hidden="true"
        >
          {nine.months.map((m) => (
            <span class="ghcal__month" style={`grid-column: ${m.col + 1}`}>{m.label}</span>
          ))}
        </div>
        <div class="ghcal__grid" role="img" aria-label={aria}>
          {nine.weeks.map((week) =>
            week.map((level) => (
              <span class:list={["ghcal__cell", level === null ? "is-empty" : `lvl-${level}`]} />
            )),
          )}
        </div>
      </div>

      {/* Mobile / narrow: full 12 months. */}
      <div class="ghcal ghcal--full" style={`--nweeks: ${full.weeks.length}`}>
        <div
          class="ghcal__months"
          style={`grid-template-columns: repeat(${full.weeks.length}, minmax(0, 1fr))`}
          aria-hidden="true"
        >
          {full.months.map((m) => (
            <span class="ghcal__month" style={`grid-column: ${m.col + 1}`}>{m.label}</span>
          ))}
        </div>
        <div class="ghcal__grid" role="img" aria-label={aria}>
          {full.weeks.map((week) =>
            week.map((level) => (
              <span class:list={["ghcal__cell", level === null ? "is-empty" : `lvl-${level}`]} />
            )),
          )}
        </div>
      </div>

      <p class="ghstrip__stat">
        <span><strong>{c.total}</strong> contributions in the last year</span>
        <span class="ghcal__key">
          <span>Less</span>
          {scale.map((l) => <span class:list={["ghcal__cell", "ghcal__keycell", `lvl-${l}`]} />)}
          <span>More</span>
        </span>
      </p>
    </div>

    <div class="ghlang" aria-label="Top languages by share of authored code">
      <span class="ghstrip__label ghlang__label">Languages</span>
      <ul class="ghlang__list">
        {languages.map((l) => (
          <li class="ghlang__row">
            <span class="ghlang__name">{l.name}</span>
            <span class="ghlang__bar" aria-hidden="true">
              <span class="ghlang__fill" style={`width: ${l.pct}%`} />
            </span>
            <span class="ghlang__pct">{l.display}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<style>
  .ghstrip {
    /* --cell sizes only the legend key swatches now; the calendar cells flex
       to fill their column via the grids below. */
    --cell: clamp(9px, 1.1vw, 13px);
    --cellgap: 3px;
    width: 100%;
    margin-top: clamp(1.6rem, 1rem + 1.5vw, 2.4rem);
    display: grid;
    gap: 0.5rem;
  }

  .ghstrip__top {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.3rem 1rem;
  }

  .ghstrip__label,
  .ghstrip__link {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    font-weight: 600;
    letter-spacing: var(--track-label);
    text-transform: uppercase;
  }

  .ghstrip__label {
    color: var(--accent-deep);
  }

  .ghstrip__link {
    color: var(--muted);
    text-decoration: none;
  }

  .ghstrip__link:hover {
    color: var(--accent-deep);
  }

  /* The body is a single column on mobile; the desktop breakpoint below turns
     it into a 3fr calendar / 1fr languages grid. */
  .ghstrip__body {
    display: grid;
    gap: 0.5rem;
  }

  .ghstrip__calcol {
    display: grid;
    gap: 0.5rem;
    min-width: 0;
  }

  /* ----- contribution calendar ----- */
  .ghcal {
    display: grid;
    gap: 0.3rem;
    min-width: 0;
  }

  /* Mobile shows the full year; the 9-month grid is desktop-only. */
  .ghcal--nine {
    display: none;
  }

  .ghcal__months {
    display: grid;
    column-gap: var(--cellgap);
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--track-meta);
    color: var(--faint);
    line-height: 1;
  }

  .ghcal__month {
    grid-row: 1;
    justify-self: start;
    white-space: nowrap;
  }

  .ghcal__grid {
    display: grid;
    grid-template-columns: repeat(var(--nweeks), minmax(0, 1fr));
    grid-template-rows: repeat(7, auto);
    grid-auto-flow: column;
    gap: var(--cellgap);
  }

  .ghcal__cell {
    aspect-ratio: 1;
    border-radius: 2px;
    background: var(--line);
  }

  .ghcal__cell.is-empty {
    background: transparent;
  }

  .lvl-0 {
    background: var(--line);
  }
  .lvl-1 {
    background: color-mix(in srgb, var(--accent) 28%, var(--paper));
  }
  .lvl-2 {
    background: color-mix(in srgb, var(--accent) 52%, var(--paper));
  }
  .lvl-3 {
    background: color-mix(in srgb, var(--accent) 76%, var(--paper));
  }
  .lvl-4 {
    background: var(--accent);
  }

  .ghstrip__stat {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem 1rem;
    margin: 0;
    font-size: var(--fs-small);
    color: var(--muted);
  }

  .ghstrip__stat strong {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    color: var(--ink);
    margin-right: 0.1rem;
  }

  .ghcal__key {
    display: inline-flex;
    align-items: center;
    gap: var(--cellgap);
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--track-meta);
    text-transform: uppercase;
    color: var(--faint);
  }

  .ghcal__keycell {
    width: var(--cell);
    height: var(--cell);
    border-radius: 2px;
  }

  .ghcal__key > span:first-child {
    margin-right: 0.15rem;
  }
  .ghcal__key > span:last-child {
    margin-left: 0.15rem;
  }

  /* ----- languages panel (desktop only) ----- */
  .ghlang {
    display: none;
    min-width: 0;
  }

  .ghlang__label {
    display: block;
    margin-bottom: 0.6rem;
  }

  .ghlang__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
  }

  .ghlang__row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    column-gap: 0.6rem;
    row-gap: 0.2rem;
    font-size: var(--fs-small);
    color: var(--muted);
  }

  .ghlang__name {
    grid-column: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ghlang__pct {
    grid-column: 2;
    justify-self: end;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    color: var(--ink);
  }

  .ghlang__bar {
    grid-column: 1 / -1;
    height: 6px;
    border-radius: 3px;
    background: var(--line);
    overflow: hidden;
  }

  .ghlang__fill {
    display: block;
    height: 100%;
    /* Literal percentage width set inline; the floor keeps sub-0.5% bars
       (Stata, JavaScript) visibly a bar rather than vanishing. Uniform accent
       fill so the panel reads as one figure with the calendar. */
    min-width: 6px;
    border-radius: 3px;
    background: var(--accent);
  }

  @media (min-width: 56em) {
    .ghstrip__body {
      grid-template-columns: 3fr 1fr;
      gap: clamp(1.4rem, 1rem + 2vw, 3rem);
      align-items: start;
    }

    .ghcal--full {
      display: none;
    }
    .ghcal--nine {
      display: grid;
    }
    .ghlang {
      display: block;
    }
  }
</style>
